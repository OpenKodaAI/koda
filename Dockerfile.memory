FROM rust:1.94-slim AS builder

RUN apt-get update && apt-get install -y --no-install-recommends protobuf-compiler \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build
COPY proto/ proto/
COPY rust/ rust/
WORKDIR /build/rust
RUN cargo build --release -p koda-memory-engine

FROM debian:13.4-slim

RUN useradd -m -s /bin/bash svcuser

COPY --from=builder /build/rust/target/release/koda-memory-engine /usr/local/bin/koda-memory-engine

USER svcuser

EXPOSE 50063

CMD ["koda-memory-engine"]
