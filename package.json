{
  "name": "koda-workspace",
  "private": true,
  "packageManager": "pnpm@10.26.2",
  "pnpm": {
    "overrides": {
      "brace-expansion@1.1.12": "1.1.13",
      "brace-expansion@5.0.4": "5.0.5",
      "flatted@3.4.1": "3.4.2",
      "picomatch@2.3.1": "2.3.2",
      "picomatch@4.0.3": "4.0.4"
    }
  },
  "scripts": {
    "dev:web": "pnpm --filter koda-web dev",
    "dev:stack": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up",
    "dev:stack:build": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build",
    "dev:stack:down": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down",
    "dev:stack:logs": "docker compose -f docker-compose.yml -f docker-compose.dev.yml logs -f web app",
    "build:release:bundle": "python3 scripts/build_release_bundle.py",
    "lint:web": "pnpm --filter koda-web lint",
    "test:web": "pnpm --filter koda-web test",
    "build:web": "pnpm --filter koda-web build"
  }
}
