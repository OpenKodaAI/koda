# Koda quickstart bootstrap
# Copy this file to .env only if you want to edit values manually.
# The official Docker-first flow is:
#   ./scripts/install.sh
#   open /control-plane/setup in the dashboard

# === Control plane bootstrap ===
CONTROL_PLANE_ENABLED=true
CONTROL_PLANE_BIND=0.0.0.0
CONTROL_PLANE_PORT=8090
WEB_PORT=3000
# Auth mode defaults to "token". Use "development" only for the source/dev stack,
# and "open" only for deliberate local-only debugging.
# CONTROL_PLANE_AUTH_MODE=token
CONTROL_PLANE_API_TOKEN=replace-with-a-random-token
# During token rotation, set comma-separated values: new-token,old-token
# CONTROL_PLANE_API_TOKEN=new-token,old-token
CONTROL_PLANE_RATE_LIMIT=120
CONTROL_PLANE_AUTH_FAILURE_RATE_LIMIT=5
RUNTIME_LOCAL_UI_TOKEN=replace-with-a-random-runtime-token
WEB_OPERATOR_SESSION_SECRET=replace-with-a-random-web-session-secret

# === Shared runtime/storage defaults ===
STATE_BACKEND=postgres
OBJECT_STORAGE_REQUIRED=true
STATE_ROOT_DIR=/var/lib/koda/state
RUNTIME_EPHEMERAL_ROOT=/var/lib/koda/runtime
ARTIFACT_STORE_DIR=/var/lib/koda/artifacts
KNOWLEDGE_V2_STORAGE_MODE=primary
KNOWLEDGE_V2_POSTGRES_SCHEMA=knowledge_v2

# === Postgres (required -- docker-compose will fail if unset) ===
POSTGRES_DB=koda
POSTGRES_USER=koda
POSTGRES_PASSWORD=replace-with-a-random-postgres-password

# === Object storage credentials (required -- docker-compose will fail if unset) ===
S3_ACCESS_KEY_ID=replace-with-a-random-object-storage-access-key
S3_SECRET_ACCESS_KEY=replace-with-a-random-object-storage-secret

# === Redis (read-only agent tool) ===
# REDIS_ENABLED=false
# REDIS_URL=redis://localhost:6379/0

# === Object storage bucket / endpoint settings ===
KNOWLEDGE_V2_S3_BUCKET=koda-objects
KNOWLEDGE_V2_S3_PREFIX=koda
KNOWLEDGE_V2_S3_ENDPOINT_URL=http://seaweedfs:8333
KNOWLEDGE_V2_S3_REGION=us-east-1

# === Master key rotation ===
# During master key rotation, set the old key so existing secrets can still be decrypted:
# CONTROL_PLANE_MASTER_KEY_PREVIOUS_FILE=/var/lib/koda/state/control_plane/.master-previous.key

# === Database pool tuning ===
# DB_POOL_MAX_SIZE=5

# === Admin & audit ===
# Comma-separated Telegram user IDs with admin privileges.
# Defaults to ALLOWED_USER_IDS when unset (all allowed users are admins).
# ADMIN_USER_IDS=
# Number of days to retain audit events before automatic cleanup.
AUDIT_RETENTION_DAYS=90

# === MCP Bridge ===
# MCP_ENABLED=false
# MCP_OAUTH_ENABLED=true
# Required for non-local OAuth popup/callback flows. When unset, only loopback
# callback URLs such as http://127.0.0.1:3000 are accepted.
# MCP_OAUTH_CALLBACK_BASE_URL=http://localhost:3000

# === Skills v2 ===
# SKILLS_V2_ENABLED=true

# === Browser security ===
# Allow browser automation to access localhost and private/reserved IP addresses.
# Only effective for runtime live scopes. Keep false unless runtime tasks need
# to reach services on the host or internal network.
# BROWSER_ALLOW_PRIVATE_NETWORK=false

# === Queue resilience ===
# Hard cap for pending turns per user before new interactive messages are rejected.
# MAX_QUEUED_TASKS_PER_USER=25
# Maximum number of startup recoveries for the same persisted queue item before
# it is routed to the DLQ instead of being re-enqueued forever.
# QUEUE_MAX_RECOVERY_ATTEMPTS=3

# === Telegram polling resumption (P1-2 of production roadmap) ===
# When false (default), restarts no longer drop queued user messages —
# Telegram's server-side offset replays anything pending. Set to true only
# if you specifically want the legacy "discard backlog on reboot" behavior.
# TELEGRAM_DROP_PENDING_UPDATES=false

# === Policy engine (Phase 1C of production roadmap, resolves P2-7/P2-8) ===
# Opt-in: when true, the queue manager consults koda-policy-engine
# before enqueuing each user message and after every billed LLM call.
# Decisions: rate-limit (per workspace), concurrent-agent slots,
# monthly spend cap with warning + hard-stop thresholds. Set workspace
# policies via the gRPC UpdatePolicy RPC.
# POLICY_ENGINE_ENABLED=false
# POLICY_ENGINE_GRPC_TARGET=policy-engine:50067
# POLICY_ENGINE_WORKSPACE_ID=ws_default

# === Bot gateway (Phase 1B of production roadmap, resolves P2-6) ===
# Opt-in: when true, workers stop opening their own long-poll TCP
# connection to api.telegram.org and instead consume their per-agent
# Update stream from the central koda-bot-gateway service. Default off
# so existing single-host deployments keep their current behavior. The
# gateway service is included in docker-compose.yml; flip this to true
# after rolling the gateway image to your fleet.
# BOT_GATEWAY_ENABLED=false
# BOT_GATEWAY_GRPC_TARGET=bot-gateway:50066
# BOT_GATEWAY_TELEGRAM_BASE_URL=https://api.telegram.org
# BOT_GATEWAY_POLL_TIMEOUT_SECONDS=25
# BOT_GATEWAY_POLL_BATCH_LIMIT=100

# === Channel integrations (per-agent — configure in the control-plane UI) ===
# These secrets are managed per-agent through the Identity > Channels section.
# Listed here for reference only. Do NOT set them in this file.
#
# Telegram:       AGENT_TOKEN
# WhatsApp:       WHATSAPP_ACCESS_TOKEN, WHATSAPP_PHONE_NUMBER_ID, WHATSAPP_VERIFY_TOKEN
# Discord:        DISCORD_BOT_TOKEN
# Slack:          SLACK_BOT_TOKEN, SLACK_APP_TOKEN, SLACK_SIGNING_SECRET
# Microsoft Teams: TEAMS_APP_ID, TEAMS_APP_PASSWORD
# LINE:           LINE_CHANNEL_SECRET, LINE_CHANNEL_ACCESS_TOKEN
# Messenger:      MESSENGER_PAGE_ACCESS_TOKEN, MESSENGER_VERIFY_TOKEN, MESSENGER_APP_SECRET
# Signal:         SIGNAL_PHONE_NUMBER, SIGNAL_CLI_URL          (não oficial)
# Instagram:      INSTAGRAM_PAGE_ACCESS_TOKEN, INSTAGRAM_APP_SECRET  (não oficial)

# === Webhook base URL (required for webhook-based channels) ===
# Public HTTPS URL for receiving webhooks from WhatsApp, Teams, LINE, Messenger, Instagram.
# The runtime appends /webhooks/<channel_type>/<agent_id> to this base.
# CHANNEL_WEBHOOK_BASE_URL=https://your-domain.com

# === gRPC TLS (optional, recommended for production) ===
# GRPC_TLS_ENABLED=true
# GRPC_TLS_CA_CERT=/path/to/ca.pem
# GRPC_TLS_CLIENT_CERT=/path/to/client.pem
# GRPC_TLS_CLIENT_KEY=/path/to/client.key

# === HTTP-only LLM providers (OpenAI-compatible) ===
# All seven providers below speak the OpenAI chat-completions wire format and
# authenticate via Bearer API key. Subscription-style OAuth is NOT available
# from any of them today; even paid Pro tiers issue a separate API key.
# Connect them in the control-plane UI (System > Integrations) — env vars
# below are bootstrap-only and override the catalog defaults.

# Perplexity (Sonar models, native web search with citations)
# PERPLEXITY_ENABLED=true
# PERPLEXITY_API_KEY=
# PERPLEXITY_API_BASE_URL=https://api.perplexity.ai
# PERPLEXITY_DEFAULT_MODEL=sonar-pro
# PERPLEXITY_TIMEOUT=180
# PERPLEXITY_FIRST_CHUNK_TIMEOUT=60

# Mistral La Plateforme (chat + Codestral + Pixtral vision + Magistral reasoning + Mistral OCR)
# MISTRAL_ENABLED=true
# MISTRAL_API_KEY=
# MISTRAL_API_BASE_URL=https://api.mistral.ai
# MISTRAL_DEFAULT_MODEL=mistral-large-latest

# Qwen via Alibaba DashScope International (Qwen3 chat/vision/coder/omni + Wan video + Qwen-TTS + Paraformer ASR)
# QWEN_ENABLED=true
# QWEN_API_KEY=
# QWEN_API_BASE_URL=https://dashscope-intl.aliyuncs.com
# QWEN_DEFAULT_MODEL=qwen3-plus

# Kimi (Moonshot AI) — Kimi K2.6 / K2.5 / Moonshot v1
# KIMI_ENABLED=true
# KIMI_API_KEY=
# KIMI_API_BASE_URL=https://api.moonshot.ai
# KIMI_DEFAULT_MODEL=kimi-k2.6

# Groq (LPU inference: GPT-OSS, Kimi K2 hosted, Qwen3, Llama 3.3, Whisper transcription)
# GROQ_ENABLED=true
# GROQ_API_KEY=
# GROQ_API_BASE_URL=https://api.groq.com/openai
# GROQ_DEFAULT_MODEL=openai/gpt-oss-120b

# DeepSeek (V4 Pro + V4 Flash; legacy aliases deepseek-chat / deepseek-reasoner deprecam em 2026/07/24)
# DEEPSEEK_ENABLED=true
# DEEPSEEK_API_KEY=
# DEEPSEEK_API_BASE_URL=https://api.deepseek.com
# DEEPSEEK_DEFAULT_MODEL=deepseek-v4-flash

# xAI Grok (Grok 4.3 recommended; Grok 4.1 Fast tem 2M de contexto; image gen via grok-image-1/pro)
# XAI_ENABLED=true
# XAI_API_KEY=
# XAI_API_BASE_URL=https://api.x.ai
# XAI_DEFAULT_MODEL=grok-4.3

# === Local Apple Silicon / Metal inference ===
# llama.cpp (Metal-accelerated GGUF models via llama-server).
# Install: `brew install llama.cpp`. Run:
#   llama-server -m <model.gguf> -ngl 99 --host 127.0.0.1 --port 8080
# LLAMACPP_ENABLED=false
# LLAMACPP_API_BASE_URL=http://127.0.0.1:8080
# LLAMACPP_API_KEY=                                # Optional; only when fronted by a proxy
# LLAMACPP_DEFAULT_MODEL=qwen2.5-7b-instruct-q4_k_m
# LLAMACPP_AVAILABLE_MODELS=qwen2.5-7b-instruct-q4_k_m,llama-3.2-3b-instruct-q4_k_m
# LLAMACPP_TIMEOUT=300
# LLAMACPP_FIRST_CHUNK_TIMEOUT=60
# LLAMACPP_BIN=llama-server                        # Override if not on PATH
# LLAMACPP_DRAFT_MODEL=                            # Speculative decoding draft model
# LLAMACPP_GRAMMAR_FILE=                           # Override bundled <agent_cmd> GBNF

# MLX (Apple-native inference via mlx-openai-server).
# Install: `pip install mlx-lm`. Run:
#   python -m mlx_lm.server --model <mlx-model> --host 127.0.0.1 --port 8000
# MLX_ENABLED=false
# MLX_API_BASE_URL=http://127.0.0.1:8000
# MLX_API_KEY=
# MLX_DEFAULT_MODEL=mlx-community/Qwen2.5-7B-Instruct-4bit
# MLX_AVAILABLE_MODELS=mlx-community/Qwen2.5-7B-Instruct-4bit,mlx-community/Llama-3.2-3B-Instruct-4bit
# MLX_TIMEOUT=300
# MLX_FIRST_CHUNK_TIMEOUT=60
# MLX_SERVER_BIN=mlx_lm.server

# === Local-runtime supervision (opt-in process management) ===
# When true, Koda spawns and supervises the local servers above and tears
# them down on shutdown. Default off — bring your own process. Heavy-slot
# lock prevents two ≥30B models loading at once (unified memory would OOM).
# LOCAL_RUNTIME_AUTO_SPAWN=false
# LOCAL_RUNTIME_HEAVY_SLOTS=1
# LOCAL_RUNTIME_QUEUE_TIMEOUT=300
# LOCAL_MODEL_REGISTRY_PATH=~/.koda/models

# === Auto-activation of local-inference quality bolt-ons ===
# When true (default), enabling a local provider (LLAMACPP_ENABLED,
# MLX_ENABLED, or OLLAMA_ENABLED) lights up the practices that make sense
# for the actual environment: reranker if sentence-transformers is
# installed, FAISS vector cache if faiss-cpu is installed, cascade routing
# at threshold 0.4, auto-spawn if the binary is on PATH. Explicit env vars
# below (RERANK_ENABLED=false, etc.) always override.
# Set this to false if you want every bolt-on off until you flip it
# yourself — the v1.0 conservative default.
# LOCAL_AUTO_OPTIMIZE=true

# === Constrained decoding (Phase 1 quality bolt-on) ===
# When true and the provider supports grammar (currently llama.cpp), Koda
# attaches a GBNF grammar that bounds output to syntactically-valid
# <agent_cmd> blocks. Eliminates parse failures from small local models.
# STRUCTURED_DECODING_ENABLED=true

# === Reranker for memory + knowledge retrieval (Phase 2 quality bolt-on) ===
# Loads BAAI/bge-reranker-v2-m3 (~570 MB) on first use. ~5 ms/query on
# Apple Silicon (MPS). Falls back to score-based ordering when disabled.
# RERANK_ENABLED=false
# RERANK_MODEL=BAAI/bge-reranker-v2-m3
# RERANK_TOP_K=8
# RERANK_DEVICE=auto                               # auto|mps|cpu|cuda

# === Semantic cache backend (Phase 2 quality bolt-on) ===
# Default `lexical` preserves existing fuzzy + chunked match. `vector`
# upgrades to a FAISS-CPU index for paraphrase-tolerant cache hits.
# SEMANTIC_CACHE_BACKEND=lexical                   # lexical|vector
# SEMANTIC_CACHE_THRESHOLD=0.92

# === Cascade routing (Phase 4 quality bolt-on) ===
# When > 0, queries with estimated complexity below this threshold prefer
# local runtimes (llamacpp/mlx) before falling back to cloud providers.
# Per-agent override via the agent editor's "Prefer local below" slider.
# LOCAL_PREFER_BELOW_COMPLEXITY=0.0

# Optional aiohttp pool size override (default 20). Bumpear quando vários
# providers HTTP estiverem ativos simultaneamente para evitar contenção.
# HTTP_POOL_LIMIT=40

# === Notes ===
# This file is only for infrastructure/bootstrap concerns.
# Agents, provider credentials, Telegram tokens, allowed Telegram users,
# integrations, and per-agent behavior should be configured through the
# control-plane UI/API and secrets vault after first boot.
# The runtime may materialize internal per-agent env such as
# AGENT_TOOL_POLICY_JSON or AGENT_RESOURCE_ACCESS_POLICY_JSON; do not set
# those here unless you are debugging a generated runtime snapshot.
# The web dashboard listens on WEB_PORT and uses an HTTP-only operator
# session to talk to the control plane through CONTROL_PLANE_BASE_URL inside
# Docker or apps/web/.env.example during standalone local development.
# WEB_PUBLIC_BASE_URL=https://koda.example.com
# WEB_OPERATOR_SESSION_SECRET is required so operator sessions remain valid
# across web restarts; only use ALLOW_INSECURE_WEB_OPERATOR_SESSION_SECRET=true
# for deliberate local-only experiments outside production.
#
# For advanced configuration, see:
#   docs/install/local.md
#   docs/install/vps.md
#   docs/config/reference.md
