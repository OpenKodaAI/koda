# Koda web UI local development
# Copy to .env.local only when running the Next.js app outside Docker.

CONTROL_PLANE_BASE_URL=http://127.0.0.1:8090
HOST=0.0.0.0
PORT=3000
WEB_OPERATOR_SESSION_SECRET=replace-with-a-random-web-session-secret
# For the source/dev stack only:
# CONTROL_PLANE_AUTH_MODE=development
# For deliberate local-only experiments you may opt into an ephemeral secret:
# ALLOW_INSECURE_WEB_OPERATOR_SESSION_SECRET=true
