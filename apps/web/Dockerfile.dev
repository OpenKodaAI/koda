FROM node:25-slim

WORKDIR /workspace

ENV NODE_ENV=development
ENV NEXT_TELEMETRY_DISABLED=1
ENV npm_config_store_dir=/root/.local/share/pnpm/store

RUN corepack enable

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/web/package.json apps/web/package.json
COPY packages/cli/package.json packages/cli/package.json

RUN pnpm install --frozen-lockfile --store-dir /root/.local/share/pnpm/store \
    && mkdir -p /opt/koda-dev-web/node_modules-root \
    && mkdir -p /opt/koda-dev-web/node_modules-app \
    && mkdir -p /opt/koda-dev-web/pnpm-store \
    && cp -a node_modules/. /opt/koda-dev-web/node_modules-root/ \
    && cp -a apps/web/node_modules/. /opt/koda-dev-web/node_modules-app/ \
    && if [ -d /root/.local/share/pnpm/store ]; then cp -a /root/.local/share/pnpm/store/. /opt/koda-dev-web/pnpm-store/; fi \
    && cat package.json pnpm-lock.yaml apps/web/package.json | sha1sum | awk '{print $1}' > /opt/koda-dev-web/pnpm-deps.sha1

WORKDIR /workspace

EXPOSE 3000

CMD ["sh", "/workspace/scripts/dev/run_web_dev.sh"]
